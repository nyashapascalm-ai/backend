generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                 Int       @id @default(autoincrement())
  name               String
  description        String?
  price              Float
  currency           String    @default("USD")
  affiliateLink      String?
  commissionRate     Float?
  network            String?
  category           String?
  profitabilityScore Float?
  trendScore         Float?
  status             String    @default("active")
  slug               String?   @unique
  imageUrl           String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  content            Content[]
  clicks             Click[]
}

model Content {
  id              Int      @id @default(autoincrement())
  productId       Int
  type            String
  title           String?
  scriptText      String?
  caption         String?
  hashtags        String?
  thumbnailPrompt String?
  cta             String?
  status          String   @default("draft")
  postUrl         String?
  sponsored       Boolean  @default(false)
  sponsorBrand    String?
  sponsorFee      Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  product         Product  @relation(fields: [productId], references: [id])
}

model Click {
  id        Int      @id @default(autoincrement())
  productId Int
  ip        String?
  userAgent String?
  referer   String?
  country   String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  firstName String?
  status    String   @default("active")
  source    String?
  createdAt DateTime @default(now())
}

model Ad {
  id          Int      @id @default(autoincrement())
  title       String
  advertiser  String
  size        String
  position    String
  mediaUrl    String
  linkUrl     String
  altText     String?
  startDate   DateTime
  endDate     DateTime
  fee         Float?
  status      String   @default("active")
  impressions Int      @default(0)
  clicks      Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}